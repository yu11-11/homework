.adoption-page {
  padding: 28rpx 24rpx 40rpx;
}

.adoption-header {
  margin-bottom: 24rpx;
}

.adoption-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #243127;
}

.adoption-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6f7c72;
}

.pet-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.pet-card {
  overflow: hidden;
}

.pet-image {
  width: 100%;
  height: 320rpx;
  background: #ffe8ef;
}

.pet-content {
  padding: 24rpx;
}

.pet-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.pet-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #243127;
}

.pet-type {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f0e0bb;
  color: #6f5624;
  font-size: 22rpx;
}

.pet-age {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #6f7c72;
}

.pet-intro {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #425146;
}
