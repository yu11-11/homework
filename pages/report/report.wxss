.report-page {
  padding: 28rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top right, #d7ecff 0%, transparent 32%),
    linear-gradient(180deg, #eef7ff 0%, #f6fbff 100%);
}

.form-card {
  background: #f3f9ff;
}

.header {
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #243127;
}

.header-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6f7c72;
}

.form-card {
  padding: 8rpx 24rpx;
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #eef1e8;
}

.form-item:last-child {
  border-bottom: 0;
}

.label {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #243127;
}

.picker-value,
.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: #324236;
  font-size: 26rpx;
}

.textarea {
  min-height: 220rpx;
}

.upload-box {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #ffffff;
}

.upload-placeholder {
  text-align: center;
  color: #5f7f99;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.submit-button {
  margin-top: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: 0;
  border-radius: 999rpx;
  background: #243127;
  color: #fffdf8;
  font-size: 28rpx;
  font-weight: 600;
}

.submit-button::after {
  border: 0;
}
